  "keyFeatures": [
    "Framework-agnostic core with adapters for React, Vue, Angular, Solid, Lit, and Svelte",
    "First-class TypeScript support with fully inferred types for nested fields",
    "Headless UI components for maximum flexibility",
    "Reactive form state management with granular subscriptions",
    "Built-in validation with sync/async support and debouncing",
    "Schema-based validation with Zod, Yup, Valibot, and Standard Schema support",
    "Array and nested object field management",
    "SSR integration for Next.js, TanStack Start, and Remix",
    "DevTools support for debugging",
    "Form composition for large, complex forms"
  ],
